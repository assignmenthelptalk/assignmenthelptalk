---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'About Us', href: '/about-us/' },
  { label: 'Order Now', href: '/order-now/' },
  { label: 'Contact', href: '/contact/' },
];

const currentPath = Astro.url.pathname;
---
<header class="bg-white shadow-sm sticky top-0 z-50">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center" aria-label="Assignment Help Talk - Home">
        <span class="text-xl font-bold text-primary">Assignment Help Talk</span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-6" role="navigation" aria-label="Main navigation">
        {navLinks.map(({ label, href }) => (
          <a
            href={href}
            class={`text-sm font-medium transition-colors hover:text-primary ${
              currentPath === href ? 'text-primary font-semibold' : 'text-gray-700'
            }`}
          >
            {label}
          </a>
        ))}
        <a
          href="/order-now/"
          class="bg-secondary text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-orange-600 transition-colors"
        >
          Place Order
        </a>
      </nav>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg text-gray-700 hover:bg-gray-100"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Nav -->
    <nav id="mobile-menu" class="md:hidden hidden pb-4" role="navigation" aria-label="Mobile navigation">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class="block py-2 text-sm font-medium text-gray-700 hover:text-primary"
        >
          {label}
        </a>
      ))}
      <a
        href="/order-now/"
        class="block mt-2 bg-secondary text-white text-sm font-semibold px-4 py-2 rounded-lg text-center hover:bg-orange-600 transition-colors"
      >
        Place Order
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden', isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  }
</script>
