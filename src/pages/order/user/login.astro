---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Login - Assignment Help Talk"
  description="Login or register to place your assignment order with Assignment Help Talk."
  canonical="https://assignmenthelptalk.com/order/user/login"
  robots="noindex, nofollow"
>
  <div class="container mx-auto px-4 py-16 max-w-md">
    <h1 class="text-3xl font-extrabold text-dark mb-8 text-center">You must login/register to place order</h1>

    <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-8">
      <form class="space-y-5">
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
            placeholder="your@email.com"
          />
        </div>
        <div>
          <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
            placeholder="••••••••"
          />
        </div>
        <button
          type="submit"
          class="w-full bg-primary text-white font-bold py-3 rounded-lg hover:bg-blue-700 transition-colors"
        >
          Login
        </button>
      </form>

      <p class="text-center text-sm text-gray-600 mt-6">
        Don't have an account?
        <a href="/order-now/" class="text-primary hover:underline font-medium">Order Now</a>
      </p>
    </div>
  </div>
</BaseLayout>
