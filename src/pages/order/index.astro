---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Place an Order - Assignment Help Talk"
  description="Place your assignment order securely. Login or register to get started with Assignment Help Talk."
  canonical="https://assignmenthelptalk.com/order/"
  robots="noindex, nofollow"
>
  <div class="container mx-auto px-4 py-20 max-w-2xl text-center">
    <h1 class="text-4xl font-extrabold text-dark mb-6">Place Your Order</h1>
    <p class="text-gray-600 mb-8 text-lg">
      Please log in or register to place your assignment order with Assignment Help Talk.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/order/user/login"
        class="bg-primary text-white font-bold px-8 py-3 rounded-lg hover:bg-blue-700 transition-colors"
      >
        Login to Order
      </a>
      <a
        href="/order-now/"
        class="bg-secondary text-white font-bold px-8 py-3 rounded-lg hover:bg-orange-600 transition-colors"
      >
        Learn More
      </a>
    </div>
  </div>
</BaseLayout>
