---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';
---
<BaseLayout
  title="Assignment Help For Students From Assignment Experts"
  description="Hire The Best Personal Assignment Writer Today. Assignment writing service for someone who needs to see the perfect results fast. Place An Order Now! Trusted by 100,000+ happy customers."
  canonical="https://assignmenthelptalk.com/"
  robots="index, follow, max-snippet:-1, max-video-preview:-1, max-image-preview:large"
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-blue-900 to-blue-700 text-white py-20">
    <div class="container mx-auto px-4 max-w-5xl text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight">
        Hire The Best Personal Assignment Writer Today
      </h1>
      <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
        Assignment writing service for someone who needs to see the perfect results fast.
        Place An Order Now!
      </p>
      <CTAButton text="Place An Order Now" href="/order-now/" class="text-lg px-10 py-4" />
    </div>
  </section>

  <!-- Trust bar -->
  <section class="py-10 bg-gray-50 border-b">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold text-dark mb-2">Trusted by 100,000+ happy customers</h2>
      <p class="text-gray-600 max-w-2xl mx-auto">
        Students across the USA, UK, UAE, Australia, and Canada trust Assignment Help Talk for expert academic writing.
      </p>
    </div>
  </section>

  <!-- Services grid -->
  <section class="py-16">
    <div class="container mx-auto px-4 max-w-6xl">
      <h2 class="text-3xl font-bold text-dark mb-10 text-center">Our Unbeatable Services</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-md transition-shadow">
          <h2 class="text-xl font-bold text-primary mb-3">Writing</h2>
          <p class="text-gray-600 text-sm">
            Just give us the instruction and make the payment. We will write the paper from scratch.
            The full payment is after you&apos;re fully satisfied.
          </p>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-md transition-shadow">
          <h2 class="text-xl font-bold text-primary mb-3">Rewriting</h2>
          <p class="text-gray-600 text-sm">
            We will completely rewrite your paper if you&apos;ve done the research, and you need a
            specialist to make it top notch — originality guaranteed.
          </p>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-md transition-shadow">
          <h2 class="text-xl font-bold text-primary mb-3">Editing</h2>
          <p class="text-gray-600 text-sm">
            If you have a task that needs some last-minute changes, send it to us with instructions.
            We&apos;ll have it back to you ASAP.
          </p>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-md transition-shadow">
          <h2 class="text-xl font-bold text-primary mb-3">Proofreading</h2>
          <p class="text-gray-600 text-sm">
            For professional proofreading, we go over your finished work, checking spelling, grammar,
            and formatting to make sure the assignment is top-notch.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 max-w-6xl">
      <h2 class="text-3xl font-bold text-dark mb-10 text-center">Benefit from Assignment Help Talk- Extras</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h3 class="text-lg font-bold text-dark mb-2">24/7 Support</h3>
          <p class="text-gray-600 text-sm">We&apos;re always online day and night. Connect with customer support around-the-clock for any orders or urgent questions.</p>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h3 class="text-lg font-bold text-dark mb-2">Unlimited Edit</h3>
          <p class="text-gray-600 text-sm">We do all revisions free of charge. Ask your writer for adjustments and you&apos;ll have them in no time!</p>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h3 class="text-lg font-bold text-dark mb-2">Flexible Prices</h3>
          <p class="text-gray-600 text-sm">All the prices are negotiable. Just contact us on the chat and you will get a good discount. Affordability is in our DNA.</p>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h3 class="text-lg font-bold text-dark mb-2">Quick Turn Around time</h3>
          <p class="text-gray-600 text-sm">No matter how tight the deadline, you can get your paper done.</p>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h3 class="text-lg font-bold text-dark mb-2">Free Plagiarism Reports</h3>
          <p class="text-gray-600 text-sm">Originality guaranteed. We provide a FREE Plagiarism report with every assignment because originality is one of our main priorities.</p>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h3 class="text-lg font-bold text-dark mb-2">Quality Control</h3>
          <p class="text-gray-600 text-sm">We have a quality control department. Every essay must go through an extra eye to ensure quality.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About us section -->
  <section class="py-16">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="text-3xl font-bold text-dark mb-6">About Us</h2>
      <p class="text-gray-700 mb-4">
        If you are looking for an assignment help expert writer to help you with your assignment, you are in the right place.
        We offer assignment help to students in the USA, UK, UAE, Australia, and Canada. Our Writing Experts will assist you
        to write a perfect research paper, dissertation, capstone, thesis, and term papers.
      </p>
      <p class="text-gray-700 mb-4">
        If you don&apos;t have enough time to undertake thorough research on your assignment, our expert writer will help you meet
        your tight schedule. Assignment Help Talk removes all your doubts by engaging the best experts in any field.
      </p>
      <p class="text-gray-700 mb-6">
        Our Masters &amp; Ph.D. level writers will help you write specialist papers in various disciplines including:
        Nursing Projects, GIS projects, Statistics, Business plans, MBA Projects, Economics, Finance, and online class tests.
      </p>
      <CTAButton text="Order Assignment Help Now" href="/order-now/" />
    </div>
  </section>

  <!-- Services link grid -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 max-w-6xl">
      <h2 class="text-3xl font-bold text-dark mb-10 text-center">Assignment Writers For All Courses Around The World</h2>
      <p class="text-gray-600 text-center mb-8 max-w-3xl mx-auto">
        We cover an extensive range of subjects and services like Economics research paper help,
        psychology dissertation help, Marketing essay help and much more.
      </p>
      <div class="grid md:grid-cols-3 gap-4">
        <a href="/economics-paper-writing-services/" class="block bg-white border border-gray-200 rounded-lg p-4 font-medium text-primary hover:border-primary hover:shadow-sm transition-all text-sm">Economics Paper Writing Service &rarr;</a>
        <a href="/biology-paper-writing-service/" class="block bg-white border border-gray-200 rounded-lg p-4 font-medium text-primary hover:border-primary hover:shadow-sm transition-all text-sm">Biology Paper Writing Service &rarr;</a>
        <a href="/nursing-paper-writing-services/" class="block bg-white border border-gray-200 rounded-lg p-4 font-medium text-primary hover:border-primary hover:shadow-sm transition-all text-sm">Nursing Paper Writing Services &rarr;</a>
        <a href="/nursing-care-plan-writing-services/" class="block bg-white border border-gray-200 rounded-lg p-4 font-medium text-primary hover:border-primary hover:shadow-sm transition-all text-sm">Nursing Care Plan Writing Services &rarr;</a>
        <a href="/cipd-assignment-help/" class="block bg-white border border-gray-200 rounded-lg p-4 font-medium text-primary hover:border-primary hover:shadow-sm transition-all text-sm">CIPD Assignment Help &rarr;</a>
        <a href="/hr-assignment-help/" class="block bg-white border border-gray-200 rounded-lg p-4 font-medium text-primary hover:border-primary hover:shadow-sm transition-all text-sm">HR Assignment Help &rarr;</a>
        <a href="/sop-writing-services/" class="block bg-white border border-gray-200 rounded-lg p-4 font-medium text-primary hover:border-primary hover:shadow-sm transition-all text-sm">SOP Writing Services &rarr;</a>
        <a href="/lab-report-writing-services/" class="block bg-white border border-gray-200 rounded-lg p-4 font-medium text-primary hover:border-primary hover:shadow-sm transition-all text-sm">Lab Report Writing Services &rarr;</a>
        <a href="/cips-assignment-help/" class="block bg-white border border-gray-200 rounded-lg p-4 font-medium text-primary hover:border-primary hover:shadow-sm transition-all text-sm">CIPS Assignment Help &rarr;</a>
        <a href="/gis-assignment-help/" class="block bg-white border border-gray-200 rounded-lg p-4 font-medium text-primary hover:border-primary hover:shadow-sm transition-all text-sm">GIS Assignment Help &rarr;</a>
        <a href="/dnp-capstone-project-help/" class="block bg-white border border-gray-200 rounded-lg p-4 font-medium text-primary hover:border-primary hover:shadow-sm transition-all text-sm">DNP Capstone Project Help &rarr;</a>
        <a href="/capstone-project-help/" class="block bg-white border border-gray-200 rounded-lg p-4 font-medium text-primary hover:border-primary hover:shadow-sm transition-all text-sm">Capstone Project Help &rarr;</a>
        <a href="/information-technology-capstone-project-ideas/" class="block bg-white border border-gray-200 rounded-lg p-4 font-medium text-primary hover:border-primary hover:shadow-sm transition-all text-sm">IT Capstone Project Ideas &rarr;</a>
        <a href="/ilm-assignment-help/" class="block bg-white border border-gray-200 rounded-lg p-4 font-medium text-primary hover:border-primary hover:shadow-sm transition-all text-sm">ILM Assignment Help &rarr;</a>
        <a href="/finance-assignment-help/" class="block bg-white border border-gray-200 rounded-lg p-4 font-medium text-primary hover:border-primary hover:shadow-sm transition-all text-sm">Finance Assignment Help &rarr;</a>
        <a href="/business-capstone-project/" class="block bg-white border border-gray-200 rounded-lg p-4 font-medium text-primary hover:border-primary hover:shadow-sm transition-all text-sm">Business Capstone Project &rarr;</a>
        <a href="/dnp-editing-services/" class="block bg-white border border-gray-200 rounded-lg p-4 font-medium text-primary hover:border-primary hover:shadow-sm transition-all text-sm">DNP Editing Services &rarr;</a>
        <a href="/manage-operational-plan-assignment-help/" class="block bg-white border border-gray-200 rounded-lg p-4 font-medium text-primary hover:border-primary hover:shadow-sm transition-all text-sm">Manage Operational Plan Help &rarr;</a>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-16 bg-primary text-white text-center">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-3xl font-bold mb-4">Ready to Get Started?</h2>
      <p class="text-blue-100 mb-8">
        Join 100,000+ students who trust Assignment Help Talk for expert academic writing support.
      </p>
      <CTAButton text="Place Your Order Now" href="/order-now/" variant="secondary" class="text-lg px-10 py-4" />
    </div>
  </section>
</BaseLayout>
