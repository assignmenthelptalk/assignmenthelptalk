---
interface Props {
  href?: string;
  text?: string;
  variant?: 'primary' | 'secondary' | 'outline';
  class?: string;
}
const {
  href = '/order-now/',
  text = 'Place Your Order Now',
  variant = 'primary',
  class: className = '',
} = Astro.props;

const styles = {
  primary: 'bg-accent hover:bg-accent-hover text-white shadow-md hover:shadow-lg',
  secondary: 'bg-primary hover:bg-primary/90 text-white shadow-md hover:shadow-lg',
  outline: 'bg-transparent border-2 border-white text-white hover:bg-white hover:text-dark',
};
---
<a
  href={href}
  class={`inline-block font-bold px-8 py-3.5 rounded-full transition-all duration-200 text-center ${styles[variant]} ${className}`}
>
  {text}
</a>
