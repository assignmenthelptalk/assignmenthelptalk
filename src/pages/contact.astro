---
import ServiceLayout from '../layouts/ServiceLayout.astro';
---
<ServiceLayout
  title="Contact - Assignment Help Talk"
  description="Dear Customers, if you have any questions regarding our service or order, contact us directly in chat below. Our Customer Support Team is here 24/7 to help and answer any questions you might have."
  canonical="https://assignmenthelptalk.com/contact/"
  robots="index, follow, max-snippet:-1, max-video-preview:-1, max-image-preview:large"
  h1="Contact Us"
>
  <p class="text-gray-700 mb-6">Dear Customers, if you have any questions regarding our service or order, contact us directly in chat below. Our Customer Support Team is here 24/7 to help and answer any questions you might have.</p>

  <section class="mb-8">
    <h2 class="text-2xl font-bold text-dark mb-4">Get In Touch</h2>
    <div class="space-y-4">
      <div class="flex items-start gap-4 p-4 bg-card-bg rounded-xl border border-gray-100">
        <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center text-xl shrink-0">✉️</div>
        <div>
          <p class="font-semibold text-dark mb-1">Email</p>
          <a href="mailto:support@assignmenthelptalk.com" class="text-accent hover:underline">support@assignmenthelptalk.com</a>
        </div>
      </div>
      <div class="flex items-start gap-4 p-4 bg-card-bg rounded-xl border border-gray-100">
        <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center text-xl shrink-0">📞</div>
        <div>
          <p class="font-semibold text-dark mb-1">Phone / WhatsApp</p>
          <p class="text-gray-700">+(44) 731-183-9056</p>
          <p class="text-gray-700">+1 (256) 467-6541</p>
        </div>
      </div>
      <div class="flex items-start gap-4 p-4 bg-card-bg rounded-xl border border-gray-100">
        <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center text-xl shrink-0">🕐</div>
        <div>
          <p class="font-semibold text-dark mb-1">Support Hours</p>
          <p class="text-gray-700">24/7 — We're always available</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-8">
    <h2 class="text-2xl font-bold text-dark mb-4">Providing Assignment Services Globally</h2>
    <p class="text-gray-700 mb-4">Our Customer Support Team is here 24/7 to help and answer any questions you might have. We look forward to hearing from you.</p>
    <p class="text-gray-700 mb-4">We serve students in the USA, UK, UAE, Australia, Canada, Saudi Arabia, and worldwide. No matter your timezone, we're here for you.</p>
  </section>
</ServiceLayout>
