---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogTitle?: string;
  ogImage?: string;
  robots?: string;
}
const props = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead {...props} />
  </head>
  <body class="font-sans bg-white text-gray-800">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
