---
const services = [
  { label: 'Economics Paper Writing', href: '/economics-paper-writing-services/' },
  { label: 'Biology Paper Writing', href: '/biology-paper-writing-service/' },
  { label: 'Nursing Paper Writing', href: '/nursing-paper-writing-services/' },
  { label: 'Nursing Care Plan', href: '/nursing-care-plan-writing-services/' },
  { label: 'CIPD Assignment Help', href: '/cipd-assignment-help/' },
  { label: 'HR Assignment Help', href: '/hr-assignment-help/' },
  { label: 'SOP Writing Services', href: '/sop-writing-services/' },
  { label: 'Lab Report Writing', href: '/lab-report-writing-services/' },
  { label: 'CIPS Assignment Help', href: '/cips-assignment-help/' },
  { label: 'GIS Assignment Help', href: '/gis-assignment-help/' },
  { label: 'Finance Assignment Help', href: '/finance-assignment-help/' },
  { label: 'ILM Assignment Help', href: '/ilm-assignment-help/' },
];

const capstones = [
  { label: 'DNP Capstone Project Help', href: '/dnp-capstone-project-help/' },
  { label: 'Capstone Project Help', href: '/capstone-project-help/' },
  { label: 'IT Capstone Project Ideas', href: '/information-technology-capstone-project-ideas/' },
  { label: 'Nursing Capstone Project Ideas', href: '/nursing-capstone-project-ideas/' },
  { label: 'Business Capstone Project', href: '/business-capstone-project/' },
  { label: 'Nursing Capstone', href: '/nursing-capstone/' },
  { label: 'DNP Editing Services', href: '/dnp-editing-services/' },
];
---
<footer class="bg-dark text-gray-400 mt-16">
  <!-- Main footer grid -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand column -->
      <div>
        <a href="/" class="flex items-center gap-1 mb-4">
          <span class="text-lg font-extrabold text-white tracking-tight">Assignment Help</span>
          <span class="text-lg font-extrabold text-accent">Talk</span>
        </a>
        <p class="text-sm leading-relaxed mb-5">
          Professional academic writing services trusted by 100,000+ students worldwide.
        </p>
        <!-- Star rating block -->
        <div class="flex items-center gap-2 mb-4">
          <div class="flex text-accent text-base">★★★★★</div>
          <span class="text-sm text-white font-semibold">4.9/5</span>
          <span class="text-xs text-gray-500">Rating</span>
        </div>
        <p class="text-sm">
          <a href="mailto:support@assignmenthelptalk.com" class="hover:text-white transition-colors">
            support@assignmenthelptalk.com
          </a>
        </p>
        <p class="text-sm mt-1">+(44) 731-183-9056</p>
        <!-- Trust badges row -->
        <div class="mt-5 flex flex-wrap gap-2">
          <span class="text-xs bg-white/10 text-gray-300 rounded-full px-3 py-1">✓ Plagiarism Free</span>
          <span class="text-xs bg-white/10 text-gray-300 rounded-full px-3 py-1">✓ On-Time Delivery</span>
          <span class="text-xs bg-white/10 text-gray-300 rounded-full px-3 py-1">✓ 24/7 Support</span>
        </div>
      </div>

      <!-- Writing Services -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Writing Services</h4>
        <ul class="space-y-2">
          {services.map(({ label, href }) => (
            <li>
              <a href={href} class="text-sm hover:text-white hover:translate-x-0.5 transition-all inline-flex items-center gap-1.5 group">
                <span class="w-1 h-1 rounded-full bg-accent opacity-0 group-hover:opacity-100 transition-opacity shrink-0"></span>
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Capstone Services -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Capstone Services</h4>
        <ul class="space-y-2">
          {capstones.map(({ label, href }) => (
            <li>
              <a href={href} class="text-sm hover:text-white hover:translate-x-0.5 transition-all inline-flex items-center gap-1.5 group">
                <span class="w-1 h-1 rounded-full bg-accent opacity-0 group-hover:opacity-100 transition-opacity shrink-0"></span>
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Quick Links</h4>
        <ul class="space-y-2">
          {[
            { label: 'Home', href: '/' },
            { label: 'About Us', href: '/about-us/' },
            { label: 'Contact Us', href: '/contact/' },
            { label: 'Order Now', href: '/order-now/' },
            { label: 'Manage Operational Plan', href: '/manage-operational-plan-assignment-help/' },
            { label: 'Economics Research Paper Guide', href: '/how-to-write-an-economics-research-paper/' },
          ].map(({ label, href }) => (
            <li>
              <a href={href} class="text-sm hover:text-white transition-colors inline-flex items-center gap-1.5 group">
                <span class="w-1 h-1 rounded-full bg-accent opacity-0 group-hover:opacity-100 transition-opacity shrink-0"></span>
                {label}
              </a>
            </li>
          ))}
        </ul>
        <div class="mt-6">
          <a
            href="/order-now/"
            class="inline-block bg-accent text-white text-sm font-semibold px-5 py-2.5 rounded-full hover:bg-accent-hover transition-colors"
          >
            Place Order Now
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-gray-500">
      <p>&copy; {new Date().getFullYear()} AssignmentHelpTalk.com — All rights reserved.</p>
      <div class="flex gap-5">
        <a href="/about-us/" class="hover:text-gray-300 transition-colors">About</a>
        <a href="/contact/" class="hover:text-gray-300 transition-colors">Contact</a>
        <a href="/order-now/" class="hover:text-gray-300 transition-colors">Order</a>
      </div>
    </div>
  </div>
</footer>
